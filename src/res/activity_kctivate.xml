<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ko.justko.caocaosaver.KctivateActivity">

    <TextView
        android:id="@+id/introduction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:text="@string/instruction"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/introduction">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/textView14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:text="@string/activate_messag_more"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="parent" />

            <TextView
                android:id="@+id/free"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/free"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textView14" />

            <GridLayout
                android:id="@+id/free_hero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:columnCount="5"
                android:rowCount="2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/free">

                <ImageView
                    android:layout_column="0"
                    android:layout_row="0"
                    android:src="@drawable/head_caocao" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="0"
                    android:src="@drawable/head_ganning" />

                <ImageView
                    android:layout_column="2"
                    android:layout_row="0"
                    android:src="@drawable/head_lvbu" />

                <ImageView
                    android:layout_column="3"
                    android:layout_row="0"
                    android:src="@drawable/head_liubei" />

                <ImageView
                    android:layout_column="0"
                    android:layout_row="1"
                    android:src="@drawable/head_guanyu" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="1"
                    android:src="@drawable/head_zhangfei" />

                <ImageView
                    android:layout_column="2"
                    android:layout_row="1"
                    android:src="@drawable/head_machao" />

                <ImageView
                    android:layout_column="3"
                    android:layout_row="1"
                    android:src="@drawable/head_huangzhong" />

                <ImageView
                    android:layout_column="4"
                    android:layout_row="1"
                    android:src="@drawable/head_zhaoyun" />
            </GridLayout>

            <TextView
                android:id="@+id/lv1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lv1"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/free_hero" />

            <GridLayout
                android:id="@+id/lv1_hero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:columnCount="5"
                android:rowCount="2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lv1">

                <ImageView
                    android:layout_column="0"
                    android:layout_row="0"
                    android:src="@drawable/head_zhugeliang" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="0"
                    android:src="@drawable/head_hetaihou" />

                <ImageView
                    android:layout_column="2"
                    android:layout_row="0"
                    android:src="@drawable/head_zhangchunhua" />

                <ImageView
                    android:layout_column="3"
                    android:layout_row="0"
                    android:src="@drawable/head_zhangxingcai" />

                <ImageView
                    android:layout_column="4"
                    android:layout_row="0"
                    android:src="@drawable/head_zhangliao" />

                <ImageView
                    android:layout_column="0"
                    android:layout_row="1"
                    android:src="@drawable/head_zoushi" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="1"
                    android:src="@drawable/head_diaochan" />
            </GridLayout>

            <TextView
                android:id="@+id/lv2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lv2"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lv1_hero" />

            <GridLayout
                android:id="@+id/lv2_hero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:columnCount="5"
                android:rowCount="2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lv2">

                <ImageView
                    android:layout_column="0"
                    android:layout_row="0"
                    android:src="@drawable/head_sunquan" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="0"
                    android:src="@drawable/head_sunshangxiang" />

                <ImageView
                    android:layout_column="2"
                    android:layout_row="0"
                    android:src="@drawable/head_zhenji" />

                <ImageView
                    android:layout_column="3"
                    android:layout_row="0"
                    android:src="@drawable/head_zhouyu" />

                <ImageView
                    android:layout_column="4"
                    android:layout_row="0"
                    android:src="@drawable/head_sunce" />

                <ImageView
                    android:layout_column="0"
                    android:layout_row="1"
                    android:src="@drawable/head_daqiao" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="1"
                    android:src="@drawable/head_xiaoqiao" />
            </GridLayout>

            <TextView
                android:id="@+id/lv3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lv3"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lv2_hero" />

            <GridLayout
                android:id="@+id/lv3_hero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:columnCount="5"
                android:rowCount="1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lv3">

                <ImageView
                    android:layout_column="0"
                    android:layout_row="0"
                    android:src="@drawable/head_none" />

                <ImageView
                    android:layout_column="1"
                    android:layout_row="0"
                    android:src="@drawable/head_none" />

                <ImageView
                    android:layout_column="2"
                    android:layout_row="0"
                    android:src="@drawable/head_none" />

                <ImageView
                    android:layout_column="3"
                    android:layout_row="0"
                    android:src="@drawable/head_none" />

                <ImageView
                    android:layout_column="4"
                    android:layout_row="0"
                    android:src="@drawable/head_none" />

            </GridLayout>
            <Button
                android:id="@+id/openStore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/open_store"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lv3_hero"/>
        </android.support.constraint.ConstraintLayout>
    </ScrollView>
</android.support.constraint.ConstraintLayout>
